{
  "name": "selenium-tests",
  "version": "1.0.0",
  "description": "Selenium E2E Tests for Smart Parking & Reservation System",
  "main": "index.js",
  "scripts": {
    "test": "mocha tests/**/*.test.js --timeout 60000 --reporter spec",
    "test:html": "mocha tests/**/*.test.js --timeout 60000 --reporter mochawesome --reporter-options reportDir=../Test Results/HTML,reportFilename=execution-report",
    "test:login": "mocha tests/login.test.js --timeout 60000 --reporter spec",
    "test:register": "mocha tests/register.test.js --timeout 60000 --reporter spec",
    "test:navigation": "mocha tests/navigation.test.js --timeout 60000 --reporter spec",
    "test:all": "mocha tests/**/*.test.js --timeout 60000 --reporter mochawesome"
  },
  "dependencies": {
    "selenium-webdriver": "^4.27.0",
    "mocha": "^10.7.3",
    "mochawesome": "^7.1.3",
    "chromedriver": "^131.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "chai": "^5.1.1"
  }
}
